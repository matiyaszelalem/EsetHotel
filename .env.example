# ─── ESET HOTEL — Vercel Environment Variables ───
# Copy this file to .env and fill in your values.
# For Vercel: add these in Project Settings → Environment Variables.

# 1. Database Connection (Neon PostgreSQL)
# Required for all API routes and auth
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/dbname?sslmode=verify-full"

# 2. Application URL
# Used for sitemap, robots.txt, email links, and Stripe redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 3. JWT Secret for authentication
# Replace with a strong random string in production
JWT_SECRET="change-this-to-a-random-secret-in-production"

# 4. Stripe Payments
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# 5. Transactional Email (Resend)
RESEND_API_KEY="re_..."
EMAIL_FROM="Eset Hotel <reservations@esethotel.com>"
