# ─── ESET HOTEL — Environment Variables ───
# Copy this file to .env for local development.
# For Vercel: add ALL of these in Project Settings → Environment Variables.
#
# ⚠️ VERCEL DEPLOYMENT CHECKLIST:
#   1. Go to Vercel Dashboard → Project → Settings → Environment Variables
#   2. Add EVERY variable below with its production value
#   3. Set NEXT_PUBLIC_APP_URL to your Vercel domain (e.g., https://eset-hotel.vercel.app)
#   4. Deploy or redeploy the project
#   Without DATABASE_URL set on Vercel, ALL API routes (including login) will return 500.

# 1. Database Connection (Neon PostgreSQL)
# Required for all API routes and auth.
# ⚠️ This is the #1 cause of login failures on Vercel — if missing, login returns 500.
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/dbname?sslmode=verify-full"

# 2. Application URL
# Set to your Vercel deployment URL in production (NOT localhost).
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 3. JWT Secret for authentication
# Replace with a strong random string in production.
JWT_SECRET="change-this-to-a-random-secret-in-production"

# 4. Debug mode (optional)
# Set to 'true' on Vercel to see actual error messages in API responses.
# SERVER_DEBUG=true

# 5. Stripe Payments
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# 6. Transactional Email (Resend)
RESEND_API_KEY="re_..."
EMAIL_FROM="Eset Hotel <reservations@esethotel.com>"
